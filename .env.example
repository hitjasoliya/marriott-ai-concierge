# Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Database
DATABASE_URL=postgresql+asyncpg://marriott:password@postgres:5432/marriott_hotels

# Embedding (local — no API key needed)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Ranking weights (optional override)
RANKING_WEIGHTS_JSON={"semantic":0.45,"distance":0.25,"rating":0.20,"availability":0.10}

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Nominatim (use a real email to respect usage policy)
NOMINATIM_EMAIL=your@email.com
